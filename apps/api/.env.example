# ──────────────────────────────────────────────────────────────────────────────
# Swarmboard API — environment variables
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB connection string (MongoDB Atlas works great with Railway)
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/swarmboard?retryWrites=true&w=majority"

# Redis connection string.
# On Railway, add a Redis plugin and use the injected `${{Redis.REDIS_URL}}` reference.
REDIS_URL="redis://localhost:6379"

# Better Auth — REQUIRED in production.
# Generate a strong random value (>= 32 chars), e.g. `openssl rand -hex 32`.
BETTER_AUTH_SECRET="change-me-to-a-random-32-char-string"

# Public URL of THIS api service (no trailing slash).
# Local: http://localhost:3001
# Railway: https://<your-api-service>.up.railway.app  (or your custom domain)
BETTER_AUTH_URL="http://localhost:3001"

# Frontend origin(s) allowed by CORS / trusted by Better Auth.
# Comma-separate multiple origins (no trailing slash on each), e.g.
#   FRONTEND_URL="https://swarmboard-web.up.railway.app,https://app.example.com"
FRONTEND_URL="http://localhost:5173"

# OpenAI (optional — enables activity-log summarization)
OPENAI_API_KEY=""

# Server
# Railway injects PORT automatically; you do not need to set it manually.
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

{
  "name": "@swarmboard/mcp-server",
  "version": "1.1.0",
  "description": "MCP (Model Context Protocol) server that lets AI coding agents like Cursor, Claude Code, Copilot, and Windsurf report task status, post progress updates, flag blockers, and mark work complete on a swarmboard kanban board — natively, with no manual prompting.",
  "type": "module",
  "bin": {
    "swarmboard-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "swarmboard",
    "mcp",
    "modelcontextprotocol",
    "mcp-server",
    "model-context-protocol",
    "ai-agents",
    "ai-coding-agents",
    "cursor",
    "cursor-ide",
    "claude-code",
    "claude",
    "windsurf",
    "copilot",
    "github-copilot",
    "task-management",
    "kanban",
    "agent-task-tracking",
    "agent-coordination",
    "developer-productivity"
  ],
  "author": "Jomael Gemota",
  "license": "MIT",
  "homepage": "https://github.com/jomael-gemota/swarmboard#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jomael-gemota/swarmboard.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/jomael-gemota/swarmboard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@swarmboard/shared": "^0.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}

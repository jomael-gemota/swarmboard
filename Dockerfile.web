# syntax=docker/dockerfile:1.7

# ── Stage 1: build ────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

ENV PNPM_HOME=/pnpm
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

WORKDIR /app

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./
COPY packages/shared/package.json ./packages/shared/
COPY apps/web/package.json ./apps/web/

RUN pnpm install --frozen-lockfile \
    --filter @swarmboard/shared... \
    --filter @swarmboard/web...

COPY packages/shared ./packages/shared
COPY apps/web ./apps/web

# Build-time API URL (Vite bakes this into the bundle)
ARG VITE_API_URL=""
ENV VITE_API_URL=$VITE_API_URL

RUN pnpm --filter @swarmboard/shared build \
 && pnpm --filter @swarmboard/web build

# ── Stage 2: runtime (Node + serve) ───────────────────────────────────────────
FROM node:20-alpine AS runtime

ENV NODE_ENV=production

WORKDIR /app

RUN npm install -g serve@14.2.4

COPY --from=builder /app/apps/web/dist ./dist

EXPOSE 8080

# `serve` honors $PORT injected by Railway and binds on all interfaces
CMD ["sh", "-c", "serve -s dist -l tcp://0.0.0.0:${PORT:-8080}"]
